# AI Daily Report Cron Job
# Runs every day at 9:30 AM Shanghai time

SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin:/home/admin/.local/bin
HOME=/home/admin

# Daily AI Agent report at 9:30 AM
30 9 * * * cd /home/admin/.openclaw/workspace && python3 scripts/ai-daily-report.py >> /home/admin/.openclaw/workspace/data/ai-daily-report/cron.log 2>&1
